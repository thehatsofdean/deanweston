---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { formatDate } from "../../utils/date";

export async function getStaticPaths() {
  const posts = await getCollection("journal", ({ data }) => !data.draft);

  const sortedPosts = [...posts].sort((a, b) => {
    const dateDiff =
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();

    if (dateDiff !== 0) return dateDiff;

    return a.id.localeCompare(b.id);
  });

  return sortedPosts.map((post, index) => {
    const nextPost =
      sortedPosts.length > 1
        ? sortedPosts[(index + 1) % sortedPosts.length]
        : null;

    return {
      params: { slug: post.id },
      props: {
        post,
        nextRead: nextPost
          ? {
              href: `/journal/${nextPost.id}/`,
              title: nextPost.data.title,
            }
          : null,
      },
    };
  });
}

const { post, nextRead } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} bodyClass="j-entry" preloadImage="/img/sherlock-pop.webp">
  <section class="panel panel--intro panel-has-bg panel-has-bg--pink panel--centered">
    <div class="panel__image panel__image--sherlock"></div>
    <div class="grid-wrapper content">
      <div class="content-col">
        <h1>
          <span class="panel-intro__name">{formatDate(post.data.pubDate)}</span>
          <span class="visually-hidden">&thinsp;&mdash;&thinsp;</span>
          <span class="panel__text--big">{post.data.title}</span>
        </h1>
        <div class="card card--fixed-bottom">
          <span>{post.data.readTime} mins read</span>
        </div>
      </div>
    </div>
  </section>

  <section class="panel">
    <div class="grid-wrapper content">
      <div class="content-col content-col--narrow">
        <article class="j-entry__content prose">
          <Content />
          <footer class="j-entry__footer">
            <nav aria-label="Article navigation">
              <ul>   
                {nextRead && (
                  <li>
                    <a href={nextRead.href} rel="next">
                      Next read: {nextRead.title}
                    </a>
                  </li>
                )}
                  <li><a href="/journal" rel="index">More articles</a></li>
              </ul>
            </nav>
          </footer>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>