---
import "../styles/site.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../utils/date";

// Get all journal posts
const journalEntries = await getCollection("journal");

// Sort newest first
const sortedJournalEntries = journalEntries.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// Latest entry
const latestJournalEntry = sortedJournalEntries[0];

// Useful values for template
const latestJournalTitle = latestJournalEntry?.data.title;
const latestJournalSummary =
  latestJournalEntry?.data.description || latestJournalEntry?.data.summary;
const latestJournalUrl = latestJournalEntry
  ? `/journal/${latestJournalEntry.id}/`
  : null;
---

<BaseLayout title="Front-End Developer &amp; Digital Consultant (Higher Education)">
